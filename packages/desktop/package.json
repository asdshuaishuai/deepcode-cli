{
  "name": "@vegamo/deepcode-desktop",
  "version": "0.1.34",
  "description": "Deep Code Desktop — an Electron GUI client on top of the Deep Code core engine",
  "license": "MIT",
  "type": "module",
  "main": "./dist/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lessweb/deepcode-cli.git"
  },
  "scripts": {
    "typecheck": "tsc -p ./ --noEmit",
    "build": "node ./build.mjs",
    "dev": "node ./build.mjs --dev",
    "start": "electron .",
    "build-and-start": "npm run build && npm run start",
    "vendor:codegraph": "node ../../scripts/vendor-codegraph.js"
  },
  "dependencies": {
    "@vegamo/deepcode-core": "file:../core",
    "marked": "^14.1.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^33.4.11"
  }
}
